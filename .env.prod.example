# CodeArena — PRODUCTION env for docker-compose.prod.yml.
# On the server:  cp .env.prod.example .env   then fill in the CHANGE_ME values.
# Generate strong secrets with:  openssl rand -hex 32
# Never commit the real .env (it's gitignored).

# ── Database (the Postgres container) ──
POSTGRES_USER=codearena
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=codearena

# ── Auth secrets ──
SECRET=CHANGE_ME_openssl_rand_hex_32
REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_32
ADMIN_EMAIL=you@example.com            # the account that registers with this email becomes the admin

# ── App ──
FRONTEND_ORIGIN=https://codearena.kodexa.in

# ── Code executor (Codebox, running on the same host) ──
CODEBOX_API_URL=http://host.docker.internal:3000
CODEBOX_AUTH_TOKEN=CHANGE_ME_strong_token   # must equal Codebox's AUTH_TOKEN

# ── OAuth (optional — leave blank until you create the apps) ──
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email / SMTP (optional — password reset + verify) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CodeArena <you@example.com>

# ── Razorpay donations (optional) ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
